// ============================================================
// BanaSat - Prisma Şeması
// Tüm veri modeli tek dosyada. Yeni gelen biri buraya bakarak
// sistemin tamamını kavrayabilir.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUM'lar
// ============================================================

/// Kullanıcının platformdaki rolü. Bir kullanıcı hem alıcı hem
/// satıcı olabilir; ADMIN yönetim paneli içindir.
enum UserRole {
  USER
  ADMIN
}

/// Bir talebin (ilanın) yaşam döngüsü durumu.
enum ListingStatus {
  AKTIF
  BEKLEMEDE
  TAMAMLANDI
  IPTAL
}

/// Bir teklifin durumu.
enum OfferStatus {
  BEKLEMEDE
  KABUL
  RED
  GERI_CEKILDI
}

/// Sipariş / ödeme durumu.
enum OrderStatus {
  ODEME_BEKLENIYOR
  ODENDI
  HAZIRLANIYOR
  KARGODA
  TESLIM_EDILDI
  IPTAL
}

// ============================================================
// MODELLER
// ============================================================

/// Platform kullanıcısı. Hem talep oluşturabilir (alıcı) hem de
/// tekliflerde bulunabilir (satıcı).
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  bio          String?
  location     String?
  role         UserRole @default(USER)

  // Satıcı itibar göstergeleri
  isVerified  Boolean @default(false) @map("is_verified")
  ratingAvg   Float   @default(0) @map("rating_avg")
  ratingCount Int     @default(0) @map("rating_count")

  // Refresh token (hash'lenmiş olarak saklanır) - oturum yönetimi
  refreshTokenHash String? @map("refresh_token_hash")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // İlişkiler
  listings            Listing[]
  offers              Offer[]
  sentMessages        Message[]      @relation("MessageSender")
  buyerConversations  Conversation[] @relation("ConversationBuyer")
  sellerConversations Conversation[] @relation("ConversationSeller")
  orders              Order[]        @relation("OrderBuyer")
  reviewsGiven        Review[]       @relation("ReviewAuthor")
  reviewsReceived     Review[]       @relation("ReviewTarget")

  @@map("users")
}

/// Hizmet/ürün kategorisi. Frontend'deki kategori barı ve
/// kategoriler sayfasını besler.
model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  icon      String? // Frontend ikon anahtarı (örn. "Laptop")
  createdAt DateTime @default(now()) @map("created_at")

  listings Listing[]

  @@map("categories")
}

/// Talep (İlan). Alıcının "şunu arıyorum" dediği kayıt.
model Listing {
  id              String        @id @default(uuid())
  title           String
  description     String // Kısa açıklama (kart üzerinde)
  fullDescription String        @map("full_description") // Detay sayfası
  budgetMin       Decimal?      @map("budget_min") @db.Decimal(12, 2)
  budgetMax       Decimal?      @map("budget_max") @db.Decimal(12, 2)
  budgetLabel     String        @map("budget_label") // "5.000 - 10.000 TL" gibi serbest metin
  location        String?
  status          ListingStatus @default(AKTIF)
  coverImageUrl   String?       @map("cover_image_url")
  views           Int           @default(0)
  deadline        DateTime? // "X gün kaldı" hesabı için

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // İlişkiler
  images        ListingImage[]
  offers        Offer[]
  conversations Conversation[]

  @@index([categoryId])
  @@index([ownerId])
  @@index([status])
  @@map("listings")
}

/// Bir talebe ait ek görseller.
model ListingImage {
  id        String   @id @default(uuid())
  url       String
  listingId String   @map("listing_id")
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([listingId])
  @@map("listing_images")
}

/// Teklif. Satıcının bir talebe verdiği fiyat ve koşullar.
model Offer {
  id           String      @id @default(uuid())
  price        Decimal     @db.Decimal(12, 2)
  deliveryTime String      @map("delivery_time") // "3 Gün", "Hemen" gibi
  warranty     String? // "2 Yıl Garanti" gibi
  shippingInfo String?     @map("shipping_info") // "Ücretsiz", "Alıcı Öder"
  note         String
  status       OfferStatus @default(BEKLEMEDE)

  listingId String  @map("listing_id")
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  sellerId String @map("seller_id")
  seller   User   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order Order?

  // Bir satıcı aynı talebe yalnızca bir aktif teklif verebilir.
  @@unique([listingId, sellerId])
  @@index([listingId])
  @@index([sellerId])
  @@index([status])
  @@map("offers")
}

/// Alıcı ve satıcı arasındaki görüşme. Genelde bir talep bağlamında.
model Conversation {
  id        String   @id @default(uuid())
  listingId String?  @map("listing_id")
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  buyerId String @map("buyer_id")
  buyer   User   @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  sellerId String @map("seller_id")
  seller   User   @relation("ConversationSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages Message[]

  // Aynı alıcı-satıcı-talep üçlüsü için tek görüşme.
  @@unique([listingId, buyerId, sellerId])
  @@index([buyerId])
  @@index([sellerId])
  @@map("conversations")
}

/// Görüşme içindeki tek bir mesaj.
model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String @map("sender_id")
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  content String
  readAt  DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

/// Sipariş. Bir teklif kabul edildiğinde oluşur, ödeme/kargo takibi.
model Order {
  id     String      @id @default(uuid())
  status OrderStatus @default(ODEME_BEKLENIYOR)
  amount Decimal     @db.Decimal(12, 2)

  offerId String @unique @map("offer_id")
  offer   Offer  @relation(fields: [offerId], references: [id])

  buyerId String @map("buyer_id")
  buyer   User   @relation("OrderBuyer", fields: [buyerId], references: [id])

  // Teslimat bilgileri
  shippingName    String? @map("shipping_name")
  shippingPhone   String? @map("shipping_phone")
  shippingAddress String? @map("shipping_address")
  shippingCity    String? @map("shipping_city")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([buyerId])
  @@map("orders")
}

/// Değerlendirme. İşlem sonrası alıcının satıcıya verdiği puan/yorum.
model Review {
  id      String  @id @default(uuid())
  rating  Int // 1-5
  comment String?

  authorId String @map("author_id")
  author   User   @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  targetId String @map("target_id")
  target   User   @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([targetId])
  @@map("reviews")
}
